// Norden Finance — Prisma Schema
// Core finance, billing, automation, and audit models.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS
// ==========================================

enum UserRole {
  user
  admin
}

enum PlanType {
  trial
  pro
}

enum TransactionType {
  masuk
  keluar
  transfer
}

enum PaymentStatus {
  pending
  approved
  rejected
}

// ==========================================
// MODELS
// ==========================================

model Profile {
  id                  String   @id @default(cuid())
  userId              String   @unique // Firebase UID
  fullName            String?
  role                UserRole @default(user)
  plan                PlanType @default(trial)
  onboardingCompleted Boolean  @default(false)
  shortcutTokenVersion Int      @default(1)
  trialStartedAt      DateTime @default(now())
  trialEndsAt         DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
}

model BillingSubscription {
  id        String   @id @default(cuid())
  userId    String // Firebase UID
  plan      PlanType
  status    String // trial, active, expired, cancelled
  startedAt DateTime @default(now())
  expiredAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Plan {
  id           String   @id @default(cuid())
  name         String
  type         String   @default("pro") // trial, pro
  price        Float
  billingType  String? // monthly, yearly
  durationDays Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([type])
  @@index([billingType])
}

model PaymentRequest {
  id            String        @id @default(cuid())
  userId        String // Firebase UID
  plan          PlanType      @default(pro)
  billingType   String // monthly, yearly
  amount        Float
  paymentMethod String // bni, bca, qris
  proofPath     String @db.Text // Uploaded proof URL
  status        PaymentStatus @default(pending)
  adminNote     String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([userId])
  @@index([status])
}

model Balance {
  id             String        @id @default(cuid())
  userId         String // Firebase UID
  name           String // BNI, BCA, DANA, GoPay, Cash, etc.
  type           String        @default("bank") // bank, ewallet, cash
  currentBalance Float         @default(0)
  archivedAt     DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  transactions   Transaction[]
  transferDestinationTransactions Transaction[] @relation("TransferDestination")

  @@unique([userId, name])
  @@index([userId])
  @@index([userId, archivedAt])
}

model Category {
  id           String        @id @default(cuid())
  userId       String // Firebase UID
  name         String // Food, Transport, Shopping, etc.
  type         TransactionType // income, expense, transfer
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  budgets      Budget[]

  @@unique([userId, name])
  @@index([userId])
}

model Transaction {
  id              String          @id @default(cuid())
  userId          String // Firebase UID
  categoryId      String?
  walletId        String?
  transferToWalletId String?
  type            TransactionType
  amount          Float
  note            String?         @db.Text
  rawInput        String?         @db.Text
  tags            Json
  receiptMerchant String?
  receiptItems    Json?
  receiptDate     DateTime?
  transactionDate DateTime        @default(now())
  deletedAt       DateTime? // Soft delete
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  wallet   Balance?  @relation(fields: [walletId], references: [id], onDelete: SetNull)
  transferToWallet Balance? @relation("TransferDestination", fields: [transferToWalletId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([userId, transactionDate])
  @@index([categoryId])
  @@index([walletId])
  @@index([transferToWalletId])
}

model TransactionTemplate {
  id           String          @id @default(cuid())
  userId       String // Firebase UID
  name         String
  type         TransactionType @default(keluar)
  amount       Float
  categoryName String
  walletName   String
  note         String?         @db.Text
  tags         Json
  isFavorite   Boolean         @default(false)
  usageCount   Int             @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@index([userId, isFavorite])
  @@index([userId, lastUsedAt])
}

model RecurringTransaction {
  id           String          @id @default(cuid())
  userId       String // Firebase UID
  name         String
  type         TransactionType @default(keluar)
  amount       Float
  categoryName String
  walletName   String
  note         String?         @db.Text
  tags         Json
  interval     String          @default("monthly")
  dayOfMonth   Int
  nextRunAt    DateTime
  lastRunAt    DateTime?
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([userId])
  @@index([userId, isActive])
  @@index([nextRunAt, isActive])
}

model Budget {
  id           String   @id @default(cuid())
  userId       String // Firebase UID
  categoryId   String
  monthlyLimit Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
  @@index([userId])
}

model SavingGoal {
  id            String    @id @default(cuid())
  userId        String // Firebase UID
  title         String
  targetAmount  Float
  currentAmount Float     @default(0)
  deadline      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

model WishlistItem {
  id         String    @id @default(cuid())
  userId     String // Firebase UID
  name       String
  amount     Float
  url        String?   @db.Text
  status     String    @default("locked") // locked, ready, bought
  unlockDate DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
}

model Debt {
  id           String   @id @default(cuid())
  userId       String // Firebase UID
  type         String   @default("hutang") // hutang (payable), piutang (receivable)
  person       String
  amount       Float
  isSettled    Boolean  @default(false)
  tenorMonths  Int?
  monthsPaid   Int      @default(0)
  interestRate Float?
  note         String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model Paylater {
  id                String    @id @default(cuid())
  userId            String // Firebase UID
  itemName          String
  platform          String
  totalAmount       Float
  installmentAmount Float
  tenorMonths       Int
  monthsPaid        Int       @default(0)
  isSettled         Boolean   @default(false)
  dueDate           DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
}

model AppSubscription {
  id         String   @id @default(cuid())
  userId     String // Firebase UID
  name       String
  amount     Float
  billingDay Int // 1-31
  method     String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model EmergencyFundPlan {
  id             String   @id @default(cuid())
  userId         String   @unique // Firebase UID
  monthlyExpense Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

model Reminder {
  id          String    @id @default(cuid())
  userId      String // Firebase UID
  title       String
  body        String    @db.Text
  type        String    @default("manual")
  channel     String    @default("in_app")
  dueAt       DateTime?
  completedAt DateTime?
  emailSentAt DateTime?
  emailLastError String? @db.Text
  emailAttemptCount Int   @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([userId, completedAt])
  @@index([dueAt])
  @@index([channel, dueAt, emailSentAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String? // Firebase UID
  action    String
  entity    String
  entityId  String?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String // Firebase UID
  rating    Int // 1-5
  message   String   @db.Text
  status    String   @default("open") // open, reviewed, closed
  createdAt DateTime @default(now())

  @@index([userId])
}

model Streak {
  id             String    @id @default(cuid())
  userId         String    @unique
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastInputDate  DateTime?
  updatedAt      DateTime  @updatedAt

  @@index([userId])
}

model Achievement {
  id           String   @id @default(cuid())
  userId       String
  title        String
  description  String   @db.Text
  unlockedAt   DateTime @default(now())

  @@unique([userId, title])
  @@index([userId])
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String   @db.Text
  type      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, isRead])
}
