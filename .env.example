# Hostinger production runtime.
# DATABASE_URL must be Hostinger MySQL/MariaDB, not PostgreSQL.
NEXT_PUBLIC_APP_URL=https://nordenfinance.site
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME"

# Firebase Auth browser config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin is used for auth/session verification only.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Backward-compatible local names also work.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# AI parser / receipt scan.
GEMINI_API_KEY=

# At least 32 random characters. Used by /api/cron/recurring and /api/cron/reminders.
CRON_SECRET=

# Preferred secret for signed Mobile Shortcuts/NFC URLs. Falls back to CRON_SECRET if empty.
SHORTCUT_TOKEN_SECRET=

# Email Verification Provider (firebase or resend)
EMAIL_VERIFICATION_PROVIDER=firebase

# Resend email delivery for reminder emails.
RESEND_API_KEY=
EMAIL_FROM=Norden Finance <onboarding@resend.dev>
ADMIN_EMAIL=
SUPPORT_EMAIL=

# Hostinger local uploads. Do not use Firebase Storage for new uploads.
STORAGE_PROVIDER=local
UPLOAD_DIR="/home/USERNAME/domains/nordenfinance.site/uploads"
UPLOAD_PUBLIC_BASE_URL=https://nordenfinance.site/api/files
MAX_UPLOAD_SIZE_MB=5

# One-time migration only. Do not use these as runtime app variables.
# Keep POSTGRES_DATABASE_URL only while copying old data from the old PostgreSQL database.
POSTGRES_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"
MYSQL_DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME"

# Firebase Console requirement:
# Authentication -> Settings -> Authorized domains -> add nordenfinance.site
# Keep nordenfinance.vercel.app during migration until Hostinger production is verified.
